{
  "name": "monitoramento",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.dev.html dist/index.html && cp dist/index.html dist/404.html",
    "build:pages": "VITE_BASE_PATH=/monitoramento-geral-trivia/ npm run build && rm -rf docs && cp -r dist docs && cp dist/index.html docs/404.html && node scripts/sync-pages-root.mjs",
